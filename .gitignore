# Node.js dependencies
node_modules/
api/node_modules/
web/node_modules/

# Build output
dist/
api/dist/
web/dist/
.next/
web/.next/

# Local SQLite database (created on first run; never commit)
*.sqlite
*.sqlite-journal
api/*.sqlite
api/*.sqlite-journal

# Environment variables
# .env.example is committed — the real .env is not
.env
.env.local
.env.*.local
api/.env
web/.env

# Machine-local Claude overrides — each developer has their own; never commit
CLAUDE.local.md

# Facilitator planning docs — excluded from participant view of the repo
docs/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.iml

# TypeScript incremental build cache
*.tsbuildinfo

# Coverage reports
coverage/
api/coverage/
web/coverage/

# Docker
.docker/

# Misc
*.pem
.nyc_output
