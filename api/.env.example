# Application
NODE_ENV=development
PORT=3001

# Database
# Default driver is SQLite — no install, no Docker, works on macOS/Windows/Linux.
# The DB file is created automatically on first run.
DB_DRIVER=sqlite
DB_DATABASE=./pulseboard.dev.sqlite
#
# To use Postgres instead, set DB_DRIVER=postgres and fill in the values below
# (these are ignored when DB_DRIVER=sqlite):
DB_HOST=localhost
DB_PORT=5432
DB_USER=pulseboard
DB_PASS=pulseboard
DB_NAME=pulseboard
DB_POOL_SIZE=10

# Redis — leave blank to use the built-in in-memory store (no Redis needed).
# Set a URL (e.g. redis://localhost:6379) to use real Redis instead.
REDIS_URL=

# JWT (dev values — must be at least 32 characters; replace in production)
JWT_SECRET=dev-jwt-secret-change-me-please-0123456789
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-0123456789
JWT_REFRESH_EXPIRES_IN=7d

# Magic Links (dev value — must be at least 32 characters; replace in production)
MAGIC_LINK_SECRET=dev-magic-link-secret-change-me-0123456789
MAGIC_LINK_BASE_URL=http://localhost:3000

# Email (use SMTP for production, mock for development)
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pulseboard.dev

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# OpenTelemetry — optional. Leave blank for local dev (tracing stays off).
# Set to an OTLP collector (e.g. http://localhost:4318) to export traces.
OTEL_EXPORTER_OTLP_ENDPOINT=
